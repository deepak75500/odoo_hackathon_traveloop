# Traveloop root environment template
# Copy this file to .env only for local/private use.
# Do not commit real secrets.

# Backend SMTP settings used by backend/app.py.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=Traveloop <your-email@gmail.com>

# Frontend API origin used by frontend/src/api.js in deployed builds.
# Local Vite development can leave this blank because vite.config.js proxies /api.
VITE_API_URL=http://localhost:8082
